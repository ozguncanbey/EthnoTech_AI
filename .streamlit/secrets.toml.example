# Streamlit Community Cloud — Secrets yapılandırması
# Bu dosyayı kopyala: cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# Gerçek secrets.toml dosyasını asla git'e ekleme!
#
# Streamlit Cloud'da bu değerleri:
# App Settings → Secrets bölümüne gir.

YOUTUBE_API_KEY    = "buraya_youtube_api_anahtarini_yaz"
GROQ_API_KEY       = "buraya_groq_api_anahtarini_yaz"
TELEGRAM_BOT_TOKEN = "buraya_telegram_bot_tokenini_yaz"
TELEGRAM_CHAT_IDS  = "buraya_telegram_chat_idlerini_yaz"
